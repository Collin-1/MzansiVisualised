# .env.local.example
#
# Copy this file to .env.local and fill in your values.
# .env.local is NEVER committed to git (it's in .gitignore).
#
# Flask equivalent: your .env file loaded by python-dotenv
#
# In Next.js:
#   NEXT_PUBLIC_ prefix  → available in browser AND server code
#   No prefix            → available ONLY in server code (safe for secrets)

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Change to https://mzansivisualized.co.za in production

# ── Analytics (optional) ──────────────────────────────────────────────────────
# Recommended: Plausible Analytics (privacy-first, South African-friendly)
# https://plausible.io
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=mzansivisualized.co.za

# ── Newsletter (optional) ─────────────────────────────────────────────────────
# Recommended: Buttondown (free up to 1000 subscribers)
# https://buttondown.com → Settings → API Keys
BUTTONDOWN_API_KEY=your_key_here

# ── Future: database (when you outgrow the flat data files) ───────────────────
# DATABASE_URL=postgresql://user:password@host:5432/mzansi
